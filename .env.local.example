# Copy to .env.local for machine-specific dev settings (gitignored).
#
# Example: access Outline from another device on the LAN via HTTPS.
# URL=https://192.168.203.13:3000
#
# After changing URL, regenerate certs to include the hostname/IP:
#   mkcert -cert-file server/config/certs/public.cert \
#     -key-file server/config/certs/private.key \
#     "192.168.203.13" "*.outline.dev"
# Then restart: yarn dev:watch
